{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "allowImportingTsExtensions": true
  },
  "include": ["worker-configuration.d.ts", "src/**/*.ts", "test/**/*.ts"],
  "exclude": ["test/workers/**/*"]
}
